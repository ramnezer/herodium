[Unit]
Description=Herodium Auto Security System
# Wait for ClamAV before starting
After=network.target syslog.target clamav-daemon.service
StartLimitIntervalSec=0

[Service]
Type=simple
User=root
WorkingDirectory=/opt/herodium
ExecStart=/opt/herodium/venv/bin/python3 /opt/herodium/core/engine.py
Environment=PYTHONUNBUFFERED=1

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
